{
  "name": "@cloudbase/open-agent-kernel",
  "version": "0.0.1-alpha.0",
  "description": "CloudBase Open Agent Kernel — server-side agentic agent SDK with built-in CloudBase resources",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.146",
    "@anthropic-ai/sdk": "^0.93.0",
    "@cloudbase/node-sdk": "^3.18.1",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependencies": {
    "@cloudbase/manager-node": "^4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudbase/manager-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.2.0",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
