# ============================================================
# open-agent-kernel examples 环境变量配置模板
# ============================================================
# 用法：
#   1. 复制本文件：cp .env.example .env.local
#   2. 把下面的占位填成真实值
#   3. 跑任意 example：pnpm dlx tsx packages/open-agent-kernel/examples/01-quickstart.ts
#
# 注意：.env.local 已被 gitignore，不要提交真实凭证。
# ============================================================

# ── 模型凭证（所有 example 必需）────────────────────────────
# 在腾讯云 TokenHub 控制台创建：https://console.cloud.tencent.com/tokenhub
TENCENTCLOUD_TOKENHUB_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── CloudBase 环境（多数 example 用到）─────────────────────
# 你的 CloudBase 环境 ID（用于资源派生）
TCB_ENV_ID=your-env-id

# CloudBase 平台支撑密钥
# - PR #4 CloudBaseSessionStore（example 04）需要这两个
# - PR #4.5 CloudBaseStorage（example 05 cloudbase 模式）需要这两个
# - PR #6A AgsStatefulSandbox（example 08）需要这两个 + TCB_API_KEY
TCB_SECRET_ID=AKIDxxxxxxxxxxxxxxxx
TCB_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx

# ── AGS Sandbox 数据面（仅 example 08 需要）────────────────
# 长期 JWT，用于 TRW HTTP gateway Bearer auth
TCB_API_KEY=eyJxxxxxxxxxxxxxxxxxxx

# ── 可选 ───────────────────────────────────────────────────

# 默认模型（不传走 example 内置默认值）
# CLOUDBASE_AGENT_MODEL=glm-5.1

# example 04 跨进程 resume 验证用：上一次 run 打印的 conversationId
# OAK_RESUME_CONVERSATION_ID=

# example 05 切换存储后端：cloudbase 走真上传 / 不传走 InMemory
# OAK_STORAGE=cloudbase

# example 05 自定义图片路径（不传走项目根 screenshot.png）
# OAK_IMAGE_PATH=

# 打开沙箱启动进度日志（OAK_DEBUG=1 同样会打印 credential 摘要）
# OAK_DEBUG=1
